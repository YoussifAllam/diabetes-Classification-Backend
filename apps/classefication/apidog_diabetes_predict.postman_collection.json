          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gender\": \"female\",\n  \"age\": 58,\n  \"hypertension\": 1,\n  \"heart_disease\": 1,\n  \"smoking_history\": \"former\",\n  \"bmi\": 31.2,\n  \"HbA1c_level\": 7.8,\n  \"blood_glucose_level\": 168\n}"
        },
        "url": "{{baseUrl}}/api/classification/predict/",
        "description": "Older age, comorbidities, elevated HbA1c and glucose."
      }
    },
    {
