          "raw": "{\n  \"gender\": \"male\",\n  \"age\": 50,\n  \"hypertension\": 0,\n  \"heart_disease\": 0,\n  \"smoking_history\": \"no info\",\n  \"bmi\": 27.0,\n  \"HbA1c_level\": 6.0,\n  \"blood_glucose_level\": 120\n}"
        },
        "url": "{{baseUrl}}/api/classification/predict/",
        "description": "Use `no info` for smoking. Duplicate this request and change only `smoking_history` to: never | current | former | ever | not current"
