      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gender\": \"male\",\n  \"age\": 32,\n  \"hypertension\": 0,\n  \"heart_disease\": 0,\n  \"smoking_history\": \"never\",\n  \"bmi\": 22.5,\n  \"HbA1c_level\": 5.2,\n  \"blood_glucose_level\": 92\n}"
        },
        "url": "{{baseUrl}}/api/classification/predict/",
        "description": "Young, normal BMI and glucose; expects prediction 0 with lower diabetes probability."
      }
    },
    {
      "name": "200 — higher-risk profile",
